# ─────────────────────────────────────────────────────────────────────────────
# .env.test  —  copy this file to .env.test and fill in your TEST values.
#
# THIS FILE MUST NEVER POINT AT THE PRODUCTION DATABASE.
# vitest.config.ts loads this file (envFile: ".env.test") instead of .env,
# so tests run against an isolated database and can never wipe production data.
#
# Recommended setup: create a separate Supabase project (or a separate schema /
# a local Postgres instance) and put its connection string below.
# ─────────────────────────────────────────────────────────────────────────────

# !! REQUIRED — must be a TEST database, not production !!
DATABASE_URL=postgresql://postgres:password@localhost:5432/harvestlynk_test

# JWT secret — can be any random string in test; doesn't need to match prod.
JWT_SECRET=test-jwt-secret-not-for-production

# Nomba credentials — all mocked in tests, but the app module still reads them
# at import time, so provide dummy values to avoid "Missing env var" errors.
NOMBA_CLIENT_ID=test-client-id
NOMBA_CLIENT_SECRET=test-client-secret
NOMBA_PARENT_ACCOUNT_ID=test-parent-account-id
NOMBA_WEBHOOK_SECRET=test-webhook-secret
NOMBA_ENV=sandbox

# Supabase — mocked in tests; dummy values prevent startup crashes.
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
SUPABASE_ANON_KEY=test-anon-key
